# ATProto — the identity waggle writes to
PDS=hermitary.brad.quest
BSKY_HANDLE=bradwenner.photo
BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# WebDAV access to waggle itself — what Moon+ Reader sends in Basic auth
DAV_USER=brad
DAV_PASSWORD=change-me

# Local-disk fallback for non-.po DAV paths (Settings/, etc.)
PASSTHROUGH_ROOT=/data/passthrough

LOG_LEVEL=INFO
