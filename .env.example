# ATProto — the identity spacebee writes to
PDS=bsky.social
BSKY_HANDLE=you.bsky.social
BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# WebDAV access to spacebee itself — what Moon+ Reader sends in Basic auth
DAV_USER=change-me
DAV_PASSWORD=change-me

# Local-disk fallback for non-.po DAV paths (Settings/, etc.)
PASSTHROUGH_ROOT=/data/passthrough

LOG_LEVEL=INFO
